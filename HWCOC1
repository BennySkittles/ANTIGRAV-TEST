                    <div class="time-block">
                        <strong>9:00 AM</strong>
                        <span>Bible Classes</span>
                    </div>
                    <div class="time-block">
                        <strong>10:00 AM</strong>
                        <span>Morning Worship</span>
                    </div>
                </div>

                <a href="#" class="btn btn-blue">What to Expect</a>
            </div>
        </section>

        <!-- PATHWAYS / HIGHLIGHTS (Dynamic connection points) -->
        <section class="pathways">
            <div class="pathway-card" style="background-image: url('https://images.unsplash.com/photo-1529070538774-1843cb3265df?q=80&w=1000&auto=format&fit=crop');">
                <div class="pathway-card-content">
                    <h3>Community Groups</h3>
                    <p>Find your people and grow together in living rooms across the Ozarks.</p>
                    <a href="#" class="btn btn-secondary">Join a Group</a>
                </div>
            </div>
            
            <div class="pathway-card" style="background-image: url('https://images.unsplash.com/photo-1593113589914-009f22c15d22?q=80&w=1000&auto=format&fit=crop');">
                <div class="pathway-card-content">
                    <h3>Serve With Us</h3>
                    <p>Discover your purpose by being the hands and feet of Jesus in our community.</p>
                    <a href="#" class="btn btn-secondary">Get Involved</a>
                </div>
            </div>

            <div class="pathway-card" style="background-image: url('https://images.unsplash.com/photo-1493612276216-ee3925520721?q=80&w=1000&auto=format&fit=crop');">
                <div class="pathway-card-content">
                    <h3>Next Generation</h3>
                    <p>Dynamic ministries tailored for your children and teenagers to encounter God.</p>
                    <a href="#" class="btn btn-secondary">Highway Kids & Youth</a>
                </div>
            </div>
        </section>

        <!-- DEEP MEDIA INTEGRATION (Sermons) -->
        <section id="media" class="media-section">
            <div class="container">
                <div class="media-header">
                    <h2>Recent Messages</h2>
                    <a href="#" class="btn btn-secondary">View Sermon Library</a>
                </div>

                <div class="sermon-grid">
                    <!-- Sermon 1 -->
                    <a href="#" class="sermon-card">
                        <div class="sermon-img" style="background-image: url('https://images.unsplash.com/photo-1444927714506-8492d94b4e3d?q=80&w=800&auto=format&fit=crop');">
                            <div class="play-btn">▶</div>
                        </div>
                        <div class="sermon-info">
                            <span class="sermon-date">October 15, 2023</span>
                            <h3>Rooted in the Valley</h3>
                            <span class="sermon-speaker">Pastor John Doe • Series: Firm Foundation</span>
                        </div>
                    </a>

                    <!-- Sermon 2 -->
                    <a href="#" class="sermon-card">
                        <div class="sermon-img" style="background-image: url('https://images.unsplash.com/photo-1473448912268-2022ce9509d8?q=80&w=800&auto=format&fit=crop');">
                            <div class="play-btn">▶</div>
                        </div>
                        <div class="sermon-info">
                            <span class="sermon-date">October 8, 2023</span>
                            <h3>Faith Like a Mustard Seed</h3>
                            <span class="sermon-speaker">Pastor John Doe • Series: Firm Foundation</span>
                        </div>
                    </a>

                    <!-- Sermon 3 -->
                    <a href="#" class="sermon-card">
                        <div class="sermon-img" style="background-image: url('https://images.unsplash.com/photo-1507692049790-de58290a4334?q=80&w=800&auto=format&fit=crop');">
                            <div class="play-btn">▶</div>
                        </div>
                        <div class="sermon-info">
                            <span class="sermon-date">October 1, 2023</span>
                            <h3>The Movement of God</h3>
                            <span class="sermon-speaker">Guest Speaker • Series: Standalone</span>
                        </div>
                    </a>
                </div>
            </div>
        </section>

    </main>

    <!-- FOOTER & LOCATION -->
    <footer>
        <div class="container">
            <div class="footer-grid">
                <div class="footer-info">
                    <h2>Highway Church of Christ</h2>
                    <p>1234 Ozark Mountain Trail<br>Bentonville, AR 72712</p>
                    <p>hello@highwaychurch.org<br>(555) 123-4567</p>
                    <br>
                    <a href="#" class="btn btn-primary" style="background-color: var(--color-deep-green); border-color: transparent;">Get Directions</a>
                </div>
                <div class="footer-links">
                    <h3 style="margin-bottom: 20px; font-family: var(--font-heading);">Quick Links</h3>
                    <ul style="display: flex; flex-direction: column; gap: 10px;">
                        <li><a href="#">What We Believe</a></li>
                        <li><a href="#">Our Leadership</a></li>
                        <li><a href="#">Study the Bible</a></li>
                        <li><a href="#">Member Portal</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; 2023 Highway Church of Christ. All rights reserved.</p>
            </div>
        </div>
    </footer>

</body>
</html>
